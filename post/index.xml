&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;Benchmark &lt;span class="p"&gt;|&lt;/span&gt; Iterations &lt;span class="p"&gt;|&lt;/span&gt; Time/op &lt;span class="p"&gt;|&lt;/span&gt; Bytes/op &lt;span class="p"&gt;|&lt;/span&gt; Allocs/op
